# ── Core ──
JWT_SECRET=change-me-in-production
LOG_LEVEL=info

# ── Auth ──
JWT_EXPIRY=24h
AUTH_LOCKOUT_THRESHOLD=4
AUTH_LOCKOUT_DURATION_MINUTES=15
INVITE_EXPIRY_HOURS=168
PASSWORD_RESET_EXPIRY_HOURS=1
TWO_FACTOR_ISSUER=DigiNode CC
AUTH_MIN_SUBMIT_MS=600

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT_LIMIT=300
RATE_LIMIT_DEFAULT_TTL=60
RATE_LIMIT_LOGIN_LIMIT=30
RATE_LIMIT_LOGIN_TTL=60
RATE_LIMIT_2FA_LIMIT=10
RATE_LIMIT_2FA_TTL=300

# ── WebSocket ──
WS_MAX_CLIENTS=200

# ── Serial (Meshtastic) ──
SERIAL_DEVICE=
SERIAL_BAUD=115200
SERIAL_RECONNECT_BASE_MS=500
SERIAL_RECONNECT_MAX_MS=15000
SERIAL_RECONNECT_JITTER=0.2

# ── Map Tiles ──
JAWG_ACCESS_TOKEN=

# ── MQTT ──
MQTT_ENABLED=false
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CONNECT_TIMEOUT_MS=5000

# ── ADS-B ──
ADSB_ENABLED=false
ADSB_URL=http://localhost:8080/data/aircraft.json
ADSB_POLL_INTERVAL_MS=3000
ADSB_OPENSKY_ENABLED=false
ADSB_OPENSKY_CLIENT_ID=
ADSB_OPENSKY_CLIENT_SECRET=
ADSB_PLANESPOTTERS_ENABLED=true

# ── ACARS ──
ACARS_ENABLED=false
ACARS_UDP_HOST=0.0.0.0
ACARS_PORT=5555

# ── TAK ──
TAK_ENABLED=false
TAK_ADDR=
TAK_PROTOCOL=tcp
TAK_TLS=false
TAK_USERNAME=
TAK_PASSWORD=

# ── FAA ──
FAA_ONLINE_LOOKUP_ENABLED=true
FAA_ONLINE_CACHE_TTL_MINUTES=10

# ── Email (SMTP) ──
MAIL_ENABLED=false
MAIL_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Updates ──
AUTO_UPDATE_BRANCH=master
AUTO_UPDATE_REMOTE=origin

# ── Firewall ──
GEOIP_DB_PATH=
